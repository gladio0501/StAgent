# ─── Required ─────────────────────────────────────────────────────────────────
# Your OpenAI API key
OPENAI_API_KEY=sk-...

# ─── Optional ─────────────────────────────────────────────────────────────────
# OpenAI model to use (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# LangSmith tracing (optional but recommended for debugging agent runs)
LANGSMITH_API_KEY=ls__...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=stem-agent
